# MCP Security Lab Environment Variables — copy this file to `.env` and fill in values.

# Ports — adjust if any conflict with other services on the host.
NORMAL_STRICT_PORT=3001
NORMAL_REALISTIC_PORT=3002
NORMAL_TRICKY_PORT=3003
VULN_EXEC_PORT=3101
VULN_AUTHLESS_PORT=3102
VULN_FILESYSTEM_PORT=3103
VULN_CONFIG_EXEC_PORT=3104
VULN_RUNTIME_ONLY_PORT=3105
VULN_NETWORK_PORT=3201
VULN_ALLOWLIST_BYPASS_PORT=3202
VULN_HIDDEN_TRANSPORT_PORT=3203
PROXY_PUBLIC_PORT=8080
PROXY_INTERNAL_PORT=8081
CONFIG_ELEVATOR_PORT=3301
INSPECTOR_PORT=6274

# Bearer tokens for the "normal" servers — use any non-empty string in the lab.
BEARER_TOKEN_NORMAL=replace-with-a-lab-only-token
BEARER_TOKEN_REALISTIC=replace-with-a-lab-only-token
BEARER_TOKEN_TRICKY=replace-with-a-lab-only-token

# Optional scanner credentials. The lab benchmark uses only offline analyzers
# (Cisco yara_analyzer, MCPScan static taint), so leaving these empty is fine.
DEEPSEEK_API_KEY=
MCP_SCANNER_API_KEY=
MCP_SCANNER_LLM_API_KEY=
MCP_SCANNER_LLM_MODEL=gpt-4o

# Docker
COMPOSE_PROJECT_NAME=mcp-lab
