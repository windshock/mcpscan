NORMAL_TRICKY_PORT=3003
VULN_EXEC_PORT=3101
VULN_AUTHLESS_PORT=3102
VULN_FILESYSTEM_PORT=3103
VULN_CONFIG_EXEC_PORT=3104
VULN_RUNTIME_ONLY_PORT=3105
VULN_NETWORK_PORT=3201
VULN_ALLOWLIST_BYPASS_PORT=3202
VULN_HIDDEN_TRANSPORT_PORT=3203
