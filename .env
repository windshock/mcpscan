# Auth tokens for normal servers
BEARER_TOKEN_NORMAL=dev-test-token-normal-2026
BEARER_TOKEN_REALISTIC=dev-test-token-realistic-2026
BEARER_TOKEN_TRICKY=dev-test-token-tricky-2026

# Scanner API keys (optional - leave empty for stage 1 only)
