{
  "id": "gpt-researcher",
  "name": "GPT-Researcher",
  "source_url": "https://github.com/assafelovic/gpt-researcher",
  "launch": {
    "kind": "repo_compose",
    "repo_url": "https://github.com/assafelovic/gpt-researcher.git",
    "ref": "v3.4.3",
    "compose_file": "docker-compose.yml",
    "project_name": "mcpscan-ox-gpt-researcher",
    "write_files": {
      ".env": "OPENAI_API_KEY=\nOPENAI_BASE_URL=\nTAVILY_API_KEY=\nLANGCHAIN_API_KEY=\nNEXT_PUBLIC_GPTR_API_URL=http://localhost:38000\n"
    },
    "compose_overrides": {
      "services": {
        "gpt-researcher": {
          "ports": ["38000:8000"]
        },
        "gptr-nextjs": {
          "ports": ["33080:3000"]
        }
      }
    }
  },
  "healthcheck": {
    "url": "http://127.0.0.1:38000/",
    "acceptable_statuses": [200, 302, 404],
    "startup_timeout_sec": 600
  },
  "validation": {
    "scan_mode": "config_fixture",
    "fixture_name": "GPT-Researcher"
  }
}
